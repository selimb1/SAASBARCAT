# ── App ─────────────────────────────────────────────
APP_NAME=contabilizAR
DEBUG=true
SECRET_KEY=CAMBIAR_EN_PRODUCCION_32_CHARS_MIN

# ── Database ─────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/contabilizar

# ── Redis ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── AWS S3 ───────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1
S3_BUCKET_NAME=contabilizar-docs

# ── IA — Gemini (OBLIGATORIO) ─────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ── IA — OpenAI (fallback, opcional) ─────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Google OAuth2 (opcional) ──────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Microsoft OAuth2 (opcional) ───────────────────────
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ── Email ─────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=noreply@contabilizar.ar

# ── CORS ──────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]

# ── Sentry (opcional) ─────────────────────────────────
SENTRY_DSN=

# ── Storage ──────────────────────────────────────────
IMAGE_RETENTION_DAYS=90
MAX_FILES_PER_BATCH=200
MAX_FILE_SIZE_MB=20
